{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "var(--ds-content-width)",
      "wideSize": "var(--ds-container-width)"
    },
    "color": {
      "palette": [
        { "slug": "brand",      "name": "Coral",      "color": "#E17055" },
        { "slug": "accent",     "name": "Yellow",     "color": "#FDCB6E" },
        { "slug": "text",       "name": "Text",       "color": "#2d2d2d" },
        { "slug": "heading",    "name": "Heading",    "color": "#1a1a1a" },
        { "slug": "background", "name": "Background", "color": "#FAF9F6" },
        { "slug": "surface",    "name": "Surface",    "color": "#FAF9F6" },
        { "slug": "muted",      "name": "Muted",      "color": "#7c7c7c" },
        { "slug": "white",      "name": "White",      "color": "#ffffff" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "vw", "vh", "%"],
      "spacingSizes": [
        { "slug": "20", "name": "XS", "size": "0.75rem" },
        { "slug": "30", "name": "S",  "size": "1rem" },
        { "slug": "40", "name": "M",  "size": "1.5rem" },
        { "slug": "50", "name": "L",  "size": "2.25rem" },
        { "slug": "60", "name": "XL", "size": "4rem" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'SF Mono', SFMono-Regular, ui-monospace, 'DejaVu Sans Mono', Menlo, Consolas, monospace"
        }
      ],
      "fontSizes": [
        { "slug": "small",    "name": "Small",  "size": "0.875rem" },
        { "slug": "medium",   "name": "Body",   "size": "1rem" },
        { "slug": "large",    "name": "Large",  "size": "1.15rem" },
        { "slug": "x-large",  "name": "H2",     "size": "clamp(1.5rem, 3vw, 2.25rem)" },
        { "slug": "xx-large", "name": "H1",     "size": "clamp(2.25rem, 5vw, 3.5rem)" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--heading)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "300",
          "lineHeight": "1.15",
          "letterSpacing": "-0.02em"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--brand)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--heading)"
          }
        }
      },
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--brand)",
          "text": "#ffffff"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--heading)",
            "text": "#ffffff"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)"
        }
      }
    }
  },
  "templateParts": [
    { "area": "header", "name": "header", "title": "Header" },
    { "area": "footer", "name": "footer", "title": "Footer" }
  ],
  "customTemplates": [
    { "name": "blank", "title": "Blank (No Header/Footer)", "postTypes": ["page"] }
  ]
}
