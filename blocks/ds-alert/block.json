{
    "apiVersion": 3,
    "name": "developer-starter/ds-alert",
    "version": "2.1.0",
    "title": "DS Alert",
    "category": "ds-content",
    "icon": "warning",
    "description": "Styled alert / notice box with type selector and inner content.",
    "keywords": [
        "alert",
        "notice",
        "warning",
        "info"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true,
        "spacing": {
            "margin": true
        }
    },
    "attributes": {
        "type": {
            "type": "string",
            "default": "info"
        },
        "dismissible": {
            "type": "boolean",
            "default": false
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-alert.js",
    "render": "file:./render.php"
}
