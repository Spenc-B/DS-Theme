{
    "apiVersion": 3,
    "name": "developer-starter/ds-divider",
    "version": "1.3.0",
    "title": "DS Divider",
    "category": "ds-layout",
    "icon": "minus",
    "description": "Decorative section divider with optional centre icon or text label.",
    "keywords": [
        "divider",
        "separator",
        "rule",
        "hr",
        "section"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true,
        "color": {
            "text": true
        },
        "spacing": {
            "margin": true
        }
    },
    "attributes": {
        "style": {
            "type": "string",
            "default": "solid"
        },
        "label": {
            "type": "string",
            "default": ""
        },
        "lineColor": {
            "type": "string",
            "default": "#e0e0e0"
        },
        "lineHeight": {
            "type": "string",
            "default": "1px"
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-divider.js",
    "render": "file:./render.php"
}
