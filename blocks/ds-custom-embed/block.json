{
    "apiVersion": 3,
    "name": "developer-starter/ds-custom-embed",
    "version": "1.2.0",
    "title": "DS Custom Embed",
    "category": "ds-content",
    "icon": "embed-generic",
    "description": "Embed custom HTML/iframe content responsively.",
    "keywords": [
        "embed",
        "iframe",
        "html",
        "custom"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "embedCode": {
            "type": "string",
            "default": ""
        },
        "aspectRatio": {
            "type": "string",
            "default": "16by9"
        },
        "maxWidth": {
            "type": "string",
            "default": "100%"
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-custom-embed.js",
    "render": "file:./render.php"
}
