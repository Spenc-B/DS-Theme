{
    "apiVersion": 3,
    "name": "developer-starter/ds-breadcrumb",
    "version": "1.2.0",
    "title": "DS Breadcrumb",
    "category": "ds-content",
    "icon": "arrow-right-alt",
    "description": "Bootstrap breadcrumb navigation — auto-generated from page hierarchy or manual JSON items.",
    "keywords": [
        "breadcrumb",
        "navigation",
        "trail"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "separator": {
            "type": "string",
            "default": "/"
        },
        "showHome": {
            "type": "boolean",
            "default": true
        },
        "mode": {
            "type": "string",
            "default": "auto"
        },
        "itemsJson": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-breadcrumb.js",
    "render": "file:./render.php"
}
