{
    "apiVersion": 3,
    "name": "developer-starter/ds-load-more",
    "version": "2.0.0",
    "title": "DS Load More",
    "category": "ds-forms",
    "icon": "plus-alt",
    "description": "AJAX load-more button for post lists.",
    "keywords": [
        "load more",
        "ajax",
        "pagination",
        "posts"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "postType": {
            "type": "string",
            "default": "post"
        },
        "postsPerLoad": {
            "type": "integer",
            "default": 6
        },
        "buttonText": {
            "type": "string",
            "default": "Load More"
        },
        "layout": {
            "type": "string",
            "default": "grid"
        },
        "columns": {
            "type": "integer",
            "default": 3
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-load-more.js",
    "render": "file:./render.php"
}
