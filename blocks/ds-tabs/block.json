{
    "apiVersion": 3,
    "name": "developer-starter/ds-tabs",
    "version": "2.1.0",
    "title": "DS Tabs",
    "category": "ds-layout",
    "icon": "table-row-before",
    "description": "Bootstrap tabbed content container with nav tabs or pills.",
    "keywords": [
        "tabs",
        "tabbed",
        "toggle",
        "sections"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "uniqueId": {
            "type": "string",
            "default": ""
        },
        "variant": {
            "type": "string",
            "default": "tabs"
        },
        "fill": {
            "type": "boolean",
            "default": false
        },
        "justified": {
            "type": "boolean",
            "default": false
        }
    },
    "providesContext": {
        "ds-tabs/uniqueId": "uniqueId"
    },
    "editorScript": "file:../../assets/js/blocks/ds-tabs.js",
    "render": "file:./render.php"
}
