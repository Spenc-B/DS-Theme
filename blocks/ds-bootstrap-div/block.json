    "attributes": {
        "bsClasses": {
            "type": "string",
            "default": ""
        },
        "tagName": {
            "type": "string",
            "default": "div"
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-bootstrap-div.js",
    "render": "file:./render.php"
