{
    "apiVersion": 3,
    "name": "developer-starter/ds-bootstrap-div",
    "version": "2.1.0",
    "title": "DS Bootstrap Div",
    "category": "ds-layout",
    "icon": "editor-code",
    "description": "Generic wrapper element with custom Bootstrap utility classes and configurable HTML tag.",
    "keywords": [
