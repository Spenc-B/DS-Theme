{
    "apiVersion": 3,
    "name": "developer-starter/ds-accordion",
    "version": "1.2.0",
    "title": "DS Accordion",
    "category": "ds-layout",
    "icon": "list-view",
    "description": "Bootstrap accordion container — place DS Accordion Items inside.",
    "keywords": [
        "accordion",
        "faq",
        "collapse"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "uniqueId": {
            "type": "string",
            "default": ""
        },
        "alwaysOpen": {
            "type": "boolean",
            "default": false
        },
        "flush": {
            "type": "boolean",
            "default": false
        }
    },
    "providesContext": {
        "ds-accordion/uniqueId": "uniqueId",
        "ds-accordion/alwaysOpen": "alwaysOpen"
    },
    "editorScript": "file:../../assets/js/blocks/ds-accordion.js",
    "allowedBlocks": [
        "developer-starter/ds-accordion-item"
    ],
    "render": "file:./render.php"
}
