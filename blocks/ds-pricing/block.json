{
    "apiVersion": 3,
    "name": "developer-starter/ds-pricing",
    "version": "1.0.0",
    "title": "DS Pricing Card",
    "category": "developer-starter",
    "icon": "tag",
    "description": "Pricing tier card with price, feature list, and CTA button.",
    "keywords": ["pricing", "plan", "tier", "card", "lumina"],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true,
        "spacing": { "padding": true, "margin": true }
    },
    "attributes": {
        "title": { "type": "string", "source": "html", "selector": ".ds-pricing__title" },
        "price": { "type": "string", "source": "html", "selector": ".ds-pricing__price" },
        "period": { "type": "string", "source": "html", "selector": ".ds-pricing__period" },
        "featured": { "type": "boolean", "default": false },
        "buttonText": { "type": "string", "source": "html", "selector": ".ds-pricing__cta a" },
        "buttonUrl": { "type": "string", "default": "#" }
    },
    "editorScript": "file:../../assets/js/blocks/ds-pricing.js"
}
