{
    "apiVersion": 3,
    "name": "developer-starter/ds-spinner",
    "version": "2.1.0",
    "title": "DS Spinner",
    "category": "ds-content",
    "icon": "update",
    "description": "Bootstrap loading spinner with border/grow variants, colour and size options.",
    "keywords": [
        "spinner",
        "loading",
        "indicator"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "html": false,
        "className": true
    },
    "attributes": {
        "variant": {
            "type": "string",
            "default": "border"
        },
        "color": {
            "type": "string",
            "default": "primary"
        },
        "size": {
            "type": "string",
            "default": ""
        },
        "label": {
            "type": "string",
            "default": "Loading..."
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-spinner.js",
    "render": "file:./render.php"
}
