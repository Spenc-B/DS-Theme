{
    "apiVersion": 3,
    "name": "developer-starter/ds-swiper",
    "version": "2.0.0",
    "title": "DS Swiper",
    "category": "ds-layout",
    "icon": "slides",
    "description": "Swiper/carousel slider container.",
    "keywords": [
        "swiper",
        "slider",
        "carousel"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "slidesPerView": {
            "type": "integer",
            "default": 1
        },
        "spaceBetween": {
            "type": "integer",
            "default": 30
        },
        "loop": {
            "type": "boolean",
            "default": true
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        },
        "navigation": {
            "type": "boolean",
            "default": true
        },
        "pagination": {
            "type": "boolean",
            "default": true
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-swiper.js",
    "render": "file:./render.php"
}
