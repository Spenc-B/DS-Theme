{
    "apiVersion": 3,
    "name": "developer-starter/ds-card",
    "version": "2.1.0",
    "title": "DS Card",
    "category": "ds-content",
    "icon": "format-aside",
    "description": "Bootstrap card with optional image, title, body content, and CTA button.",
    "keywords": [
        "card",
        "box",
        "content",
        "cta"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true,
        "spacing": {
            "padding": true,
            "margin": true
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "default": ""
        },
        "imageId": {
            "type": "number"
        },
        "imageUrl": {
            "type": "string",
            "default": ""
        },
        "buttonText": {
            "type": "string",
            "default": ""
        },
        "buttonUrl": {
            "type": "string",
            "default": ""
        },
        "buttonVariant": {
            "type": "string",
            "default": "primary"
        },
        "headerText": {
            "type": "string",
            "default": ""
        },
        "footerText": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-card.js",
    "render": "file:./render.php"
}
