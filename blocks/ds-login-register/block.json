{
    "apiVersion": 3,
    "name": "developer-starter/ds-login-register",
    "version": "1.2.0",
    "title": "DS Login / Register",
    "category": "ds-forms",
    "icon": "admin-users",
    "description": "Login and registration form with toggle.",
    "keywords": [
        "login",
        "register",
        "user",
        "auth"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "defaultTab": {
            "type": "string",
            "default": "login"
        },
        "showRegister": {
            "type": "boolean",
            "default": true
        },
        "redirectUrl": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-login-register.js",
    "render": "file:./render.php"
}
