{
    "apiVersion": 3,
    "name": "developer-starter/ds-social-feeds",
    "version": "1.2.0",
    "title": "DS Social Feeds",
    "category": "ds-social",
    "icon": "rss",
    "description": "Display social media feed embed.",
    "keywords": [
        "social",
        "feed",
        "instagram",
        "twitter"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "platform": {
            "type": "string",
            "default": "instagram"
        },
        "embedUrl": {
            "type": "string",
            "default": ""
        },
        "postsCount": {
            "type": "integer",
            "default": 6
        },
        "columns": {
            "type": "integer",
            "default": 3
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-social-feeds.js",
    "render": "file:./render.php"
}
