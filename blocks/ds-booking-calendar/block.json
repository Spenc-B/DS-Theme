{
    "apiVersion": 3,
    "name": "developer-starter/ds-booking-calendar",
    "version": "1.2.0",
    "title": "DS Booking Calendar",
    "category": "ds-forms",
    "icon": "calendar",
    "description": "Interactive booking/availability calendar.",
    "keywords": [
        "booking",
        "calendar",
        "schedule",
        "reservation"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "calendarId": {
            "type": "string",
            "default": ""
        },
        "view": {
            "type": "string",
            "default": "month"
        },
        "firstDay": {
            "type": "integer",
            "default": 1
        },
        "bookingUrl": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-booking-calendar.js",
    "render": "file:./render.php"
}
