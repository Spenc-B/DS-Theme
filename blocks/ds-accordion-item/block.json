{
    "apiVersion": 3,
    "name": "developer-starter/ds-accordion-item",
    "version": "2.1.0",
    "title": "DS Accordion Item",
    "category": "ds-layout",
    "icon": "arrow-down-alt2",
    "description": "Bootstrap accordion item with collapsible title and inner content.",
    "keywords": [
        "accordion",
        "faq",
        "toggle",
        "collapse"
    ],
    "textdomain": "developer-starter",
    "parent": ["developer-starter/ds-accordion"],
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "title": {
            "type": "string",
            "default": "Accordion Item"
        },
        "defaultOpen": {
            "type": "boolean",
            "default": false
        },
        "uniqueId": {
            "type": "string",
            "default": ""
        }
    },
    "usesContext": [
        "ds-accordion/uniqueId",
        "ds-accordion/alwaysOpen"
    ],
    "editorScript": "file:../../assets/js/blocks/ds-accordion-item.js",
    "render": "file:./render.php"
}
