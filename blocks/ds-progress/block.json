{
    "apiVersion": 3,
    "name": "developer-starter/ds-progress",
    "version": "1.2.0",
    "title": "DS Progress",
    "category": "ds-content",
    "icon": "minus",
    "description": "Bootstrap progress bar with label, colour variants, striped and animated options.",
    "keywords": [
        "progress",
        "bar",
        "skill",
        "percentage"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true,
        "spacing": {
            "margin": true
        }
    },
    "attributes": {
        "label": {
            "type": "string",
            "default": ""
        },
        "percentage": {
            "type": "number",
            "default": 75
        },
        "showPercentage": {
            "type": "boolean",
            "default": true
        },
        "variant": {
            "type": "string",
            "default": ""
        },
        "striped": {
            "type": "boolean",
            "default": false
        },
        "animated": {
            "type": "boolean",
            "default": false
        },
        "barColor": {
            "type": "string",
            "default": ""
        },
        "height": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-progress.js",
    "render": "file:./render.php"
}
