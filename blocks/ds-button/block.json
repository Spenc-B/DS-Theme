{
    "apiVersion": 3,
    "name": "developer-starter/ds-button",
    "version": "1.2.0",
    "title": "DS Button",
    "category": "ds-content",
    "icon": "button",
    "description": "Styled button with link, variant, size, alignment, and custom colour options.",
    "keywords": [
        "button",
        "cta",
        "link"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "text": {
            "type": "string",
            "default": "Button"
        },
        "url": {
            "type": "string",
            "default": "#"
        },
        "variant": {
            "type": "string",
            "default": "primary"
        },
        "size": {
            "type": "string",
            "default": ""
        },
        "openInNewTab": {
            "type": "boolean",
            "default": false
        },
        "fullWidth": {
            "type": "boolean",
            "default": false
        },
        "align": {
            "type": "string",
            "default": ""
        },
        "backgroundColor": {
            "type": "string",
            "default": ""
        },
        "textColor": {
            "type": "string",
            "default": ""
        },
        "borderRadius": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-button.js",
    "render": "file:./render.php"
}
