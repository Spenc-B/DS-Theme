{
    "apiVersion": 3,
    "name": "developer-starter/ds-sitemap",
    "version": "2.0.0",
    "title": "DS Sitemap",
    "category": "ds-data",
    "icon": "networking",
    "description": "Auto-generated HTML sitemap of pages and posts.",
    "keywords": [
        "sitemap",
        "pages",
        "navigation"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "className": true
    },
    "attributes": {
        "postTypes": {
            "type": "array",
            "default": [
                "page",
                "post"
            ]
        },
        "showHierarchy": {
            "type": "boolean",
            "default": true
        },
        "excludeIds": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-sitemap.js",
    "render": "file:./render.php"
}
