{
    "apiVersion": 3,
    "name": "developer-starter/ds-section",
    "version": "2.0.0",
    "title": "DS Section",
    "category": "ds-layout",
    "icon": "align-full-width",
    "description": "Semantic section wrapper with optional HTML tag selector.",
    "keywords": [
        "section",
        "wrapper",
        "layout"
    ],
    "textdomain": "developer-starter",
    "supports": {
        "anchor": true,
        "html": false,
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        },
        "className": true
    },
    "attributes": {
        "tagName": {
            "type": "string",
            "default": "section"
        }
    },
    "editorScript": "file:../../assets/js/blocks/ds-section.js",
    "render": "file:./render.php"
}
